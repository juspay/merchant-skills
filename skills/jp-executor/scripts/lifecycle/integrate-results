#!/usr/bin/env bash
# Lifecycle recorder + gatekeeper for /integrate workflow. Manages step records,
# a run manifest, and workflow state in a JSON file. JSON processing: jq
# (primary) → python3/python (fallback) → exit 2 with SKILL_FALLBACK message.
#
# SECURITY: This script structurally refuses to store sensitive fields (keys,
# secrets, passwords, tokens). Credentials must stay in env vars, never in the
# results file. Verification strings must also be credential-free — the caller
# is responsible for that.
#
# RUN MANIFEST (gatekeeper): `init` seeds a bootstrap manifest
# [product-select, platform-detect, plan]. The `plan` step calls a planning
# agent that emits a run-specific steps.json, which `register` merges in. From
# then on, step-start/step-end/step reject any step name not in the manifest
# (closed vocabulary), and `finalize` / `set status completed` HARD-FAIL while
# any registered step (except `done`) has no terminal record. This converts a
# silently-skipped step into a loud, non-zero failure.
#
# Usage:
#   integrate-results init
#   integrate-results register <steps.json>
#   integrate-results step-start <name>
#   integrate-results step-end <status> "<verification>" ["<reason>"]
#   integrate-results step <name> <status> "<verification>" <startedAt> <completedAt> ["<reason>"]
#   integrate-results set <field> <value>
#   integrate-results finalize
#
# steps.json is a JSON array; each element:
#   {"name": "<closed-vocabulary name>", "guard": "<condition|always>",
#    "terminal": ["passed"] | ["passed","skipped"], "critical": true|false}
#
# Every mutation echoes a one-line confirmation on stdout:
#   init       — init: startedAt=<ts>
#   register   — registered: <new> steps (manifest=<total>)
#   step-start — pending: <name>
#   step-end   — recorded: <name> <status> (steps=<count>, pending=<none|name>)
#   step       — recorded: <name> <status> (steps=<count>)
#   set        — set: <field>=<value>
#   finalize   — complete: all manifest steps recorded   (or)   incomplete: <names>
#
# Exit codes:
#   0 — success
#   1 — usage / logic error / validation failure / incomplete manifest
#   2 — no JSON processor found (SKILL_FALLBACK)

set -euo pipefail

FILE=".integrate-results.json"

# ── Closed step vocabulary (shared by jq path; mirrored in the python heredoc) ──
# The planner may only emit names from this set. register/step-* reject others.
_is_allowed_step() {
  case "$1" in
    product-select|platform-detect|plan|doc-fetch|arch-decisions|codegen|checklist|test|summary|done|\
    android-setup|ios-setup|react-native-setup|flutter-setup|cordova-setup|capacitor-setup|web-setup|iframe-web-setup|\
    platform-disambiguation|params-collect|apikey-provision|webhook-config|return-url-config|db-schema-decision|integration-stages|stages-confirm)
      return 0 ;;
    *) return 1 ;;
  esac
}

cmd="${1:?Usage: integrate-results <init|register|step-start|step-end|step|set|expect|fulfilled|finalize> ...}"
shift

# ── JSON processor detection: jq → python3 → python → exit 2 ──────────────
if command -v jq &>/dev/null; then
  JQ=jq

elif command -v python3 &>/dev/null || command -v python &>/dev/null; then
  _PY="$(command -v python3 2>/dev/null || command -v python)"
  # Hand off entirely to Python. exec replaces this shell process.
  # Inside Python: sys.argv == ['-', cmd, ...original-args...]
  exec "$_PY" - "$cmd" "$@" <<'PYEOF'
import sys, json, os, re, datetime

FILE = ".integrate-results.json"
SENSITIVE = re.compile(r'key|secret|password|token', re.IGNORECASE)

ALLOWED_STEPS = {
    "product-select", "platform-detect", "plan", "doc-fetch", "arch-decisions",
    "codegen", "checklist", "test", "summary", "done",
    "android-setup", "ios-setup", "react-native-setup", "flutter-setup",
    "cordova-setup", "capacitor-setup", "web-setup", "iframe-web-setup",
    "platform-disambiguation", "params-collect", "apikey-provision",
    "webhook-config", "return-url-config", "db-schema-decision",
    "integration-stages", "stages-confirm",
}
# Terminal states a planner may declare for a step. `failed` is a runtime
# outcome, not something the planner pre-declares, so it's excluded here.
PLANNED_TERMINALS = {"passed", "skipped"}
STATUSES = {"passed", "failed", "skipped"}
# Steps a well-formed run manifest must always contain (each may still resolve
# to skipped-with-reason at runtime, but it cannot be absent).
REQUIRED_IN_MANIFEST = {"doc-fetch", "codegen", "test", "summary", "done"}

BOOTSTRAP = [
    {"name": "product-select", "guard": "always", "terminal": ["passed"], "critical": True},
    {"name": "platform-detect", "guard": "always", "terminal": ["passed"], "critical": True},
    {"name": "plan", "guard": "always", "terminal": ["passed"], "critical": True},
]


def now_utc():
    try:
        return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    except AttributeError:
        return datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")


def read_file():
    with open(FILE) as fh:
        return json.load(fh)


def write_file(data):
    tmp = FILE + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(data, fh, indent=2)
    os.replace(tmp, FILE)


def die(msg):
    sys.stderr.write("integrate-results: {}\n".format(msg))
    sys.exit(1)


def check_sensitive(field):
    if SENSITIVE.search(field):
        die("refusing to store sensitive field '{}' — keep credentials in env vars only".format(field))


def manifest_names(data):
    return [s.get("name", "") for s in data.get("manifest", [])]


def has_manifest(data):
    return bool(data.get("manifest"))


def missing_steps(data):
    # Manifest steps with no terminal record yet, excluding `done` (the step
    # that triggers finalize and is necessarily still in flight at that point).
    recorded = {s.get("name", "") for s in data.get("steps", [])}
    return [n for n in manifest_names(data) if n != "done" and n not in recorded]


def require_in_manifest(data, name):
    # Enforce closed-vocabulary execution only once a manifest exists. If none
    # exists (legacy file / SKILL_FALLBACK), degrade to no enforcement.
    if has_manifest(data) and name not in set(manifest_names(data)):
        die("step '{}' is not in the run manifest — register the manifest first "
            "(or the planner omitted it)".format(name))


def unmet_inputs(data, name):
    # Question gate: fields declared via `expect <name> ...` that have no
    # matching `fulfilled <name> <field>` yet. Returns the missing list.
    expected = (data.get("expected") or {}).get(name, [])
    got = set((data.get("fulfilled") or {}).get(name, []))
    return [f for f in expected if f not in got]


argv = sys.argv[1:]
if not argv:
    die("Usage: integrate-results <init|register|step-start|step-end|step|set|expect|fulfilled|finalize> ...")

cmd, rest = argv[0], argv[1:]

if cmd == "init":
    started = now_utc()
    write_file({"workflow": "integrate", "startedAt": started,
                "active": "working", "status": "running",
                "manifest": [dict(s) for s in BOOTSTRAP],
                "manifestSource": "bootstrap", "steps": []})
    sys.stdout.write("init: startedAt={}\n".format(started))

elif cmd == "register":
    if not rest:
        die("register: steps.json file path required")
    path = rest[0]
    if not os.path.exists(path):
        die("register: file '{}' not found".format(path))
    try:
        with open(path) as fh:
            incoming = json.load(fh)
    except ValueError as e:
        die("register: '{}' is not valid JSON ({})".format(path, e))
    if not isinstance(incoming, list):
        die("register: expected a JSON array of steps")

    normalized = []
    for i, s in enumerate(incoming):
        if not isinstance(s, dict) or not isinstance(s.get("name"), str):
            die("register: step #{} needs a string 'name'".format(i))
        name = s["name"]
        if name not in ALLOWED_STEPS:
            die("register: unknown step name '{}' (not in closed vocabulary)".format(name))
        terminal = s.get("terminal", ["passed"])
        if not isinstance(terminal, list) or set(terminal) - PLANNED_TERMINALS:
            die("register: step '{}' terminal must be a subset of [passed, skipped]".format(name))
        normalized.append({
            "name": name,
            "guard": s.get("guard", "always"),
            "terminal": terminal,
            "critical": bool(s.get("critical", False)),
        })

    data = read_file()
    manifest = data.get("manifest", [])
    seen = {s.get("name") for s in manifest}
    before = len(manifest)
    for s in normalized:
        if s["name"] not in seen:
            manifest.append(s)
            seen.add(s["name"])
    missing_required = REQUIRED_IN_MANIFEST - seen
    if missing_required:
        die("register: manifest missing required step(s): {}".format(
            ",".join(sorted(missing_required))))
    data["manifest"] = manifest
    data["manifestSource"] = "registered"
    write_file(data)
    sys.stdout.write("registered: {} steps (manifest={})\n".format(
        len(manifest) - before, len(manifest)))

elif cmd == "step-start":
    if not rest:
        die("name required")
    name = rest[0]
    started = now_utc()
    data = read_file()
    require_in_manifest(data, name)
    existing = (data.get("pendingStep") or {}).get("name", "")
    if existing:
        die("pendingStep '{}' already active — call step-end before starting '{}'".format(existing, name))
    data["pendingStep"] = {"name": name, "startedAt": started}
    write_file(data)
    sys.stdout.write("pending: {}\n".format(name))

elif cmd == "step-end":
    if len(rest) < 2:
        die("status and verification required")
    status, verif = rest[0], rest[1]
    reason = rest[2] if len(rest) > 2 else ""
    if status not in STATUSES:
        die("status must be one of passed|failed|skipped (got '{}')".format(status))
    if status == "skipped" and not reason:
        die("a skipped step requires a non-empty reason (3rd argument)")
    completed = now_utc()
    data = read_file()
    pending = data.get("pendingStep") or {}
    name = pending.get("name", "")
    started = pending.get("startedAt", "")
    if not name:
        die("no pendingStep — call step-start first")
    if status == "passed":
        unmet = unmet_inputs(data, name)
        if unmet:
            die("cannot close '{}' as passed — unmet required inputs: {} "
                "(collect them and call `fulfilled {} <field>`, or close as skipped)".format(
                    name, ",".join(unmet), name))
    step = {"name": name, "status": status, "verification": verif,
            "startedAt": started, "completedAt": completed}
    if reason:
        step["reason"] = reason
    data.setdefault("steps", []).append(step)
    data.pop("pendingStep", None)
    write_file(data)
    count = len(data["steps"])
    sys.stdout.write("recorded: {} {} (steps={}, pending=none)\n".format(name, status, count))

elif cmd == "step":
    if len(rest) < 5:
        die("name status verification startedAt completedAt required")
    name, status, verif, started, completed = rest[:5]
    reason = rest[5] if len(rest) > 5 else ""
    if status not in STATUSES:
        die("status must be one of passed|failed|skipped (got '{}')".format(status))
    if status == "skipped" and not reason:
        die("a skipped step requires a non-empty reason (6th argument)")
    _now = now_utc()
    if started == "now":   started   = _now
    if completed == "now": completed = _now
    data = read_file()
    require_in_manifest(data, name)
    if status == "passed":
        unmet = unmet_inputs(data, name)
        if unmet:
            die("cannot close '{}' as passed — unmet required inputs: {}".format(name, ",".join(unmet)))
    step = {"name": name, "status": status, "verification": verif,
            "startedAt": started, "completedAt": completed}
    if reason:
        step["reason"] = reason
    data.setdefault("steps", []).append(step)
    write_file(data)
    count = len(data["steps"])
    sys.stdout.write("recorded: {} {} (steps={})\n".format(name, status, count))

elif cmd == "expect":
    if len(rest) < 2:
        die("expect: step name and a comma-separated field list required")
    step_name, fields = rest[0], rest[1]
    items = [f.strip() for f in fields.split(",") if f.strip()]
    data = read_file()
    data.setdefault("expected", {})[step_name] = items
    write_file(data)
    sys.stdout.write("expected: {} needs {}\n".format(step_name, ",".join(items)))

elif cmd == "fulfilled":
    if len(rest) < 2:
        die("fulfilled: step name and field required")
    step_name, field = rest[0], rest[1]
    data = read_file()
    bag = data.setdefault("fulfilled", {}).setdefault(step_name, [])
    if field not in bag:
        bag.append(field)
    write_file(data)
    total = len((data.get("expected") or {}).get(step_name, []))
    sys.stdout.write("fulfilled: {} {} ({}/{})\n".format(step_name, field, len(bag), total))

elif cmd == "set":
    if len(rest) < 2:
        die("field and value required")
    field, value = rest[0], rest[1]
    check_sensitive(field)
    data = read_file()
    if field == "status" and value == "completed":
        miss = missing_steps(data)
        if miss:
            die("cannot set status=completed — INCOMPLETE: {}".format(",".join(miss)))
    if value == "true":    data[field] = True
    elif value == "false": data[field] = False
    else:                  data[field] = value
    write_file(data)
    sys.stdout.write("set: {}={}\n".format(field, value))

elif cmd == "finalize":
    data = read_file()
    if not has_manifest(data):
        sys.stdout.write("complete: no manifest registered (enforcement unavailable)\n")
        sys.exit(0)
    miss = missing_steps(data)
    if miss:
        sys.stdout.write("incomplete: {}\n".format(",".join(miss)))
        sys.stderr.write("integrate-results: INCOMPLETE — registered step(s) never executed: {}\n".format(",".join(miss)))
        sys.exit(1)
    sys.stdout.write("complete: all manifest steps recorded\n")

else:
    sys.stderr.write("Unknown command: {}\n".format(cmd))
    sys.stderr.write("Usage: integrate-results <init|register|step-start|step-end|step|set|expect|fulfilled|finalize> ...\n")
    sys.exit(1)
PYEOF

else
  printf 'integrate-results: no JSON processor available (need jq, python3, or python)\n' >&2
  printf 'SKILL_FALLBACK: result tracking unavailable — continue workflow without timing data\n' >&2
  exit 2
fi

# ── jq path (only reached when jq is available) ───────────────────────────

_check_sensitive_field() {
  local field
  field="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$field" in
    *key*|*secret*|*password*|*token*)
      echo "integrate-results: refusing to store sensitive field '$1' — keep credentials in env vars only" >&2
      exit 1
      ;;
  esac
}

# Enforce closed-vocabulary execution only when a manifest exists.
_has_manifest() {
  [ "$($JQ -r 'has("manifest") and ((.manifest // []) | length > 0)' "$FILE")" = "true" ]
}

_require_in_manifest() {
  local n="$1"
  if _has_manifest && [ "$($JQ -r --arg n "$n" 'any((.manifest // [])[]; .name==$n)' "$FILE")" != "true" ]; then
    echo "integrate-results: step '$n' is not in the run manifest — register the manifest first (or the planner omitted it)" >&2
    exit 1
  fi
}

_missing_steps() {
  $JQ -r '(([.manifest[]?.name] - [.steps[]?.name] - ["done"]) // []) | join(",")' "$FILE"
}

# Question gate: expected fields for a step that have no matching `fulfilled` yet.
_unmet_inputs() {
  local n="$1"
  $JQ -r --arg n "$n" '(((.expected // {})[$n] // []) - ((.fulfilled // {})[$n] // [])) | join(",")' "$FILE"
}

case "$cmd" in
  init)
    startedAt="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cat > "$FILE" <<ENDJSON
{
  "workflow": "integrate",
  "startedAt": "$startedAt",
  "active": "working",
  "status": "running",
  "manifestSource": "bootstrap",
  "manifest": [
    { "name": "product-select", "guard": "always", "terminal": ["passed"], "critical": true },
    { "name": "platform-detect", "guard": "always", "terminal": ["passed"], "critical": true },
    { "name": "plan", "guard": "always", "terminal": ["passed"], "critical": true }
  ],
  "steps": []
}
ENDJSON
    echo "init: startedAt=$startedAt"
    ;;

  register)
    stepsfile="${1:?steps.json file path required}"
    [ -f "$stepsfile" ] || { echo "integrate-results: register: file '$stepsfile' not found" >&2; exit 1; }
    $JQ -e 'type=="array"' "$stepsfile" >/dev/null 2>&1 || {
      echo "integrate-results: register: expected a JSON array of steps in '$stepsfile'" >&2; exit 1; }

    # Every element must have a string name.
    bad="$($JQ -r '[.[] | select((.name|type)!="string")] | length' "$stepsfile")"
    [ "$bad" = "0" ] || { echo "integrate-results: register: every step needs a string 'name'" >&2; exit 1; }

    # Every name must be in the closed vocabulary.
    while IFS= read -r nm; do
      _is_allowed_step "$nm" || { echo "integrate-results: register: unknown step name '$nm' (not in closed vocabulary)" >&2; exit 1; }
    done < <($JQ -r '.[].name' "$stepsfile")

    # terminal (when present) must be a subset of [passed, skipped].
    badterm="$($JQ -r '[.[] | select((((.terminal // ["passed"]) - ["passed","skipped"]) | length) > 0)] | length' "$stepsfile")"
    [ "$badterm" = "0" ] || { echo "integrate-results: register: terminal must be a subset of [passed, skipped]" >&2; exit 1; }

    before="$($JQ -r '(.manifest // []) | length' "$FILE")"
    $JQ --slurpfile inc "$stepsfile" '
      (.manifest // []) as $m
      | ([ $inc[0][] | {name, guard:(.guard // "always"), terminal:(.terminal // ["passed"]), critical:(.critical // false)} ]) as $new
      | .manifest = (reduce ($m + $new)[] as $s ([]; if any(.[]; .name==$s.name) then . else . + [$s] end))
      | .manifestSource = "registered"
    ' "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    after="$($JQ -r '.manifest | length' "$FILE")"

    # Required phase steps must be present after merge.
    for req in doc-fetch codegen test summary done; do
      [ "$($JQ -r --arg r "$req" 'any(.manifest[]; .name==$r)' "$FILE")" = "true" ] || {
        echo "integrate-results: register: manifest missing required step '$req'" >&2; exit 1; }
    done

    echo "registered: $((after - before)) steps (manifest=$after)"
    ;;

  step-start)
    name="${1:?name required}"
    _require_in_manifest "$name"
    startedAt="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    existing="$($JQ -r '.pendingStep.name // empty' "$FILE")"
    if [ -n "$existing" ]; then
      echo "integrate-results: pendingStep '$existing' already active — call step-end before starting '$name'" >&2
      exit 1
    fi
    $JQ --arg n "$name" --arg sa "$startedAt" \
       '.pendingStep = {"name":$n,"startedAt":$sa}' \
       "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    echo "pending: $name"
    ;;

  step-end)
    status="${1:?status required (passed|failed|skipped)}"
    verif="${2:?verification required}"
    reason="${3:-}"
    case "$status" in
      passed|failed|skipped) ;;
      *) echo "integrate-results: status must be one of passed|failed|skipped (got '$status')" >&2; exit 1 ;;
    esac
    if [ "$status" = "skipped" ] && [ -z "$reason" ]; then
      echo "integrate-results: a skipped step requires a non-empty reason (3rd argument)" >&2
      exit 1
    fi
    completedAt="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    name="$($JQ -r '.pendingStep.name // empty' "$FILE")"
    startedAt="$($JQ -r '.pendingStep.startedAt // empty' "$FILE")"
    if [ -z "$name" ] || [ -z "$startedAt" ]; then
      echo "integrate-results: no pendingStep — call step-start first" >&2
      exit 1
    fi

    if [ "$status" = "passed" ]; then
      unmet="$(_unmet_inputs "$name")"
      if [ -n "$unmet" ]; then
        echo "integrate-results: cannot close '$name' as passed — unmet required inputs: $unmet (collect them and call \`fulfilled $name <field>\`, or close as skipped)" >&2
        exit 1
      fi
    fi

    if [ -n "$reason" ]; then
      $JQ --arg n "$name" --arg s "$status" --arg v "$verif" \
         --arg sa "$startedAt" --arg ca "$completedAt" --arg r "$reason" \
         '.steps += [{"name":$n,"status":$s,"verification":$v,"startedAt":$sa,"completedAt":$ca,"reason":$r}] | del(.pendingStep)' \
         "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    else
      $JQ --arg n "$name" --arg s "$status" --arg v "$verif" \
         --arg sa "$startedAt" --arg ca "$completedAt" \
         '.steps += [{"name":$n,"status":$s,"verification":$v,"startedAt":$sa,"completedAt":$ca}] | del(.pendingStep)' \
         "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    fi
    count="$($JQ -r '.steps | length' "$FILE")"
    pending="$($JQ -r '.pendingStep.name // "none"' "$FILE")"
    echo "recorded: $name $status (steps=$count, pending=$pending)"
    ;;

  step)
    name="${1:?name required}"
    status="${2:?status required (passed|failed|skipped)}"
    verif="${3:?verification required}"
    startedAt="${4:?startedAt required}"
    completedAt="${5:?completedAt required}"
    reason="${6:-}"
    case "$status" in
      passed|failed|skipped) ;;
      *) echo "integrate-results: status must be one of passed|failed|skipped (got '$status')" >&2; exit 1 ;;
    esac
    if [ "$status" = "skipped" ] && [ -z "$reason" ]; then
      echo "integrate-results: a skipped step requires a non-empty reason (6th argument)" >&2
      exit 1
    fi
    _require_in_manifest "$name"
    if [ "$status" = "passed" ]; then
      unmet="$(_unmet_inputs "$name")"
      if [ -n "$unmet" ]; then
        echo "integrate-results: cannot close '$name' as passed — unmet required inputs: $unmet" >&2
        exit 1
      fi
    fi

    [[ "$startedAt" == "now" ]] && startedAt="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    [[ "$completedAt" == "now" ]] && completedAt="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    if [ -n "$reason" ]; then
      $JQ --arg n "$name" --arg s "$status" --arg v "$verif" \
         --arg sa "$startedAt" --arg ca "$completedAt" --arg r "$reason" \
         '.steps += [{"name":$n,"status":$s,"verification":$v,"startedAt":$sa,"completedAt":$ca,"reason":$r}]' \
         "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    else
      $JQ --arg n "$name" --arg s "$status" --arg v "$verif" \
         --arg sa "$startedAt" --arg ca "$completedAt" \
         '.steps += [{"name":$n,"status":$s,"verification":$v,"startedAt":$sa,"completedAt":$ca}]' \
         "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    fi
    count="$($JQ -r '.steps | length' "$FILE")"
    echo "recorded: $name $status (steps=$count)"
    ;;

  set)
    field="${1:?field required}"
    value="${2:?value required}"
    _check_sensitive_field "$field"
    if [ "$field" = "status" ] && [ "$value" = "completed" ]; then
      miss="$(_missing_steps)"
      if [ -n "$miss" ]; then
        echo "integrate-results: cannot set status=completed — INCOMPLETE: $miss" >&2
        exit 1
      fi
    fi
    if [ "$value" = "true" ] || [ "$value" = "false" ]; then
      $JQ --arg f "$field" --argjson v "$value" '.[$f] = $v' "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    else
      $JQ --arg f "$field" --arg v "$value" '.[$f] = $v' "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    fi
    echo "set: $field=$value"
    ;;

  finalize)
    if ! _has_manifest; then
      echo "complete: no manifest registered (enforcement unavailable)"
      exit 0
    fi
    miss="$(_missing_steps)"
    if [ -n "$miss" ]; then
      echo "incomplete: $miss"
      echo "integrate-results: INCOMPLETE — registered step(s) never executed: $miss" >&2
      exit 1
    fi
    echo "complete: all manifest steps recorded"
    ;;

  expect)
    step_name="${1:?step name required}"
    fields="${2:?comma-separated field list required}"
    items="$(printf '%s' "$fields" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$' || true)"
    json="$(printf '%s\n' "$items" | $JQ -R . | $JQ -s .)"
    $JQ --arg n "$step_name" --argjson v "$json" '.expected = ((.expected // {}) | .[$n] = $v)' \
      "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    echo "expected: $step_name needs $(printf '%s' "$items" | tr '\n' ',' | sed 's/,$//')"
    ;;

  fulfilled)
    step_name="${1:?step name required}"
    field="${2:?field required}"
    $JQ --arg n "$step_name" --arg f "$field" \
      '.fulfilled = ((.fulfilled // {}) | .[$n] = (((.[$n] // []) + [$f]) | unique))' \
      "$FILE" > "${FILE}.tmp" && mv "${FILE}.tmp" "$FILE"
    got="$($JQ -r --arg n "$step_name" '((.fulfilled // {})[$n] // []) | length' "$FILE")"
    total="$($JQ -r --arg n "$step_name" '((.expected // {})[$n] // []) | length' "$FILE")"
    echo "fulfilled: $step_name $field ($got/$total)"
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    echo "Usage: integrate-results <init|register|step-start|step-end|step|set|expect|fulfilled|finalize> ..." >&2
    exit 1
    ;;
esac
